{
  "name": "abstraction-tree-monorepo",
  "private": true,
  "version": "0.2.0-beta.1",
  "description": "Local-first abstraction tree and visual codebase understanding system.",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/cli",
    "packages/app",
    "packages/full"
  ],
  "scripts": {
    "build": "npm run build -w @abstraction-tree/core && npm run build -w @abstraction-tree/cli && npm run build -w @abstraction-tree/app",
    "dev:app": "npm run dev -w @abstraction-tree/app",
    "lint": "node scripts/lint.mjs",
    "typecheck": "npm run build -w @abstraction-tree/core && npm run typecheck -w @abstraction-tree/core && npm run typecheck -w @abstraction-tree/cli && npm run typecheck -w @abstraction-tree/app",
    "coverage": "node scripts/run-coverage.mjs",
    "format": "node scripts/format.mjs --write",
    "format:check": "node scripts/format.mjs --check",
    "check:unicode": "node scripts/check-unicode.mjs",
    "docs:commands": "node scripts/check-doc-commands.mjs",
    "audit:security": "npm audit --audit-level=high",
    "package:size": "node scripts/check-package-size.mjs",
    "pack:smoke": "node scripts/pack-smoke-test.mjs",
    "release:changelog": "node scripts/check-changelog.mjs",
    "release:dry-run": "node scripts/release-dry-run.mjs",
    "atree": "node packages/cli/dist/index.js",
    "atree:scan": "node packages/cli/dist/index.js scan --project .",
    "atree:validate": "node packages/cli/dist/index.js validate --project . --strict",
    "atree:evaluate": "node packages/cli/dist/index.js evaluate --project .",
    "atree:export": "node packages/cli/dist/index.js export --project .",
    "atree:goal": "node packages/cli/dist/index.js goal --project .",
    "atree:route": "node packages/cli/dist/index.js route --project .",
    "atree:scope:check": "node packages/cli/dist/index.js scope check --project . --scope latest",
    "test": "node scripts/run-tests.mjs",
    "missions:plan": "node scripts/run-missions.mjs --plan",
    "missions:run": "node scripts/run-missions.mjs",
    "missions:plan:manual": "node scripts/run-missions.mjs --missions .abstraction-tree/missions --plan",
    "missions:run:manual": "node scripts/run-missions.mjs --missions .abstraction-tree/missions",
    "assessment:pack": "node scripts/create-assessment-pack.mjs",
    "assessment:import": "node scripts/import-assessment-missions.mjs",
    "self:loop": "node scripts/run-full-self-improvement-loop.mjs",
    "diff:summary": "node scripts/diff-summary.mjs",
    "diff:summary:windows": "powershell -ExecutionPolicy Bypass -File scripts/summarize-diff.ps1",
    "abstraction:loop:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-abstraction-loop.ps1",
    "abstraction:loop:visible:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-abstraction-loop-scheduled.ps1",
    "codex:missions:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-codex-missions.ps1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "license": "MIT",
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
